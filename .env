# Entorno
# Cambia el valor de NODE_ENV a "production" para producción
# Cambia el valor de NODE_ENV a "development" para desarrollo
#NODE_ENV=production
NODE_ENV=development
FORCE_HARDWARE_CONNECTION=true

# Puerto del servidor backend
PORT=3000

# Configuración POS
TBK_PORT_PATH=/dev/ttyACM0 
TBK_PORT_PATH2=/dev/ttyACM1
TBK_BAUD_RATE=115200
TBK_TIMEOUT=30000

# Seguridad CORS - acepta múltiples si es necesario
# Este valor se ignora en modo desarrollo si usas origin: '*'
ALLOWED_ORIGINS=*
#ALLOWED_ORIGINS=http://localhost:3000, http://192.168.8.53:3000

